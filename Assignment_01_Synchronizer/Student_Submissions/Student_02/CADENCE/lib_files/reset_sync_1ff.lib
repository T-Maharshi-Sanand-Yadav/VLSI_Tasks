      internal_power () {
        when : "!CLK * !D";
        related_pg_pin : VSS;
        rise_power (passive_power_template_2x1) {
          index_1 ("0.008, 0.28");
          values ( \
            "0.000182961, 0.000189138" \
          );
        }
        fall_power (passive_power_template_2x1) {
          index_1 ("0.008, 0.28");
          values ( \
            "0.000116648, 0.000124422" \
          );
        }
      }
    }
    ff (IQ,IQB) {
      clear : "!RST";
      clocked_on : "CLK";
      next_state : "D";
      power_down_function : "(!VDD) + (VSS)";
    }
  }
}
